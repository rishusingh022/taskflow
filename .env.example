# Used by docker-compose for the Postgres container (defaults match DATABASE_URL below)
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow
POSTGRES_DB=taskflow

# API — required by the Go binary (compose passes these through)
JWT_SECRET=super-secret-key-change-in-prod
PORT=8080
# From the API container, host `db` is the Postgres service name
DATABASE_URL=postgres://taskflow:taskflow@db:5432/taskflow?sslmode=disable
